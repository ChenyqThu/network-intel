# Network Intel backend — environment configuration (copy to .env)
# All values shown are the defaults; the system runs fully offline as-is.

# --- HTTP server ---
NINTEL_HOST=0.0.0.0
NINTEL_PORT=8000
# Comma-separated CORS allow-list (the web dev server).
NINTEL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Storage ---
# NINTEL_DATA_DIR=./data
# NINTEL_DB_PATH=./data/nintel.db

# --- Pipeline behaviour ---
# fixture (default) | live   — 'live' connectors raise NotImplementedError here.
NINTEL_CONNECTOR_MODE=fixture
# manual (default) | auto    — 'manual' writes to data/pending awaiting approval.
NINTEL_REVIEW_MODE=manual

# Per-source live opt-in (subset of A,B,C,G,H). Empty => live mode raises per source.
# NINTEL_LIVE_SOURCES=A,B,C

# --- LLM stage (optional; OFF by default, never called in tests) ---
# false (default) | true     — 'true' routes classify→Haiku, curate→Opus.
NINTEL_LLM_ENABLED=false
# Required only when NINTEL_LLM_ENABLED=true:
# ANTHROPIC_API_KEY=sk-ant-...        # or a crs key: cr_...
# Custom Anthropic-compatible endpoint (e.g. claude-relay-service / crs):
# ANTHROPIC_BASE_URL=http://127.0.0.1:8765/api
# NINTEL_HAIKU_MODEL=claude-haiku-4-5-20251001
# NINTEL_OPUS_MODEL=claude-opus-4-8

# --- Selection / cross-day re-surface (WS1) ---
# NINTEL_RESURFACE_HEAT_DELTA=50
# NINTEL_RESURFACE_HEAT_RATIO=2.0
# NINTEL_RESURFACE_COOLDOWN_DAYS=3
# NINTEL_SELECT_MIN_HEAT=0
# NINTEL_SELECT_MAX_ITEMS_DAILY=12

# --- RAG knowledge base (optional; needs LLM enabled) ---
# NINTEL_RAG_ENABLED=false
# NINTEL_RAG_CLASSIFY=false
# Background backend: local sqlite-vec corpus, or the kos/gbrain service.
# NINTEL_KB_BACKEND=local            # local | gbrain
# NINTEL_EMBEDDER=fastembed          # fastembed | hash (history collection)
# kos/gbrain (when NINTEL_KB_BACKEND=gbrain) — OAuth client_credentials:
# KOS_MCP_BASE=http://127.0.0.1:7225
# KOS_OAUTH_CLIENT_ID=gbrain_cl_...
# KOS_OAUTH_CLIENT_SECRET=gbrain_cs_...

# --- Live source credentials (only when NINTEL_CONNECTOR_MODE=live) ---
# Source B — UNIFI_CHANNELS Supabase:
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_KEY=<service-role-key>
# Source A — omada-sentiment-monitor Notion:
# NOTION_TOKEN=ntn_...
# NOTION_DATABASE_ID=<reddit-db>
# NOTION_YOUTUBE_DATABASE_ID=<youtube-db>
# Source C — industry RSS. Inline list and/or a catalog file (the verified
# feeds live in config/industry_feeds.txt):
# NINTEL_RSS_FEEDS=https://www.cnx-software.com/feed/,https://wifinowglobal.com/feed/
# NINTEL_RSS_FEEDS_FILE=config/industry_feeds.txt
# Source G — Gemini deep-research (weekly grounded prompts -> industry items):
# NINTEL_GEMINI_API_KEY=AIza...
# NINTEL_GEMINI_MODEL=gemini-2.5-pro
# Source H — HTML scrape of no-feed official sources (SITES in
# connectors/html_scrape.py); needs no creds, just enable H in NINTEL_LIVE_SOURCES.
