{% import '_macros.html.j2' as m %}
<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="x-apple-disable-message-reformatting">
<meta name="color-scheme" content="light">
<meta name="supported-color-schemes" content="light">
<title>Network Intel · {{ report.date_range }} · 周报</title>
<!--[if mso]><style>*{font-family:'Segoe UI',Arial,sans-serif !important;}</style><![endif]-->
<style>
  a{text-decoration:none;}
  .hov:hover{opacity:.82;}
  @media only screen and (max-width:620px){
    .wrap{width:100% !important;}
    .px{padding-left:18px !important;padding-right:18px !important;}
    .stack{display:block !important;width:100% !important;}
  }
</style>
</head>
<body style="margin:0;padding:0;background:#F4F3EE;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">

<div style="display:none;max-height:0;overflow:hidden;opacity:0;color:#F4F3EE;font-size:1px;line-height:1px;">
  {{ report.lead.strong or report.title }} — 含市场策略洞察与数据看板。每条结论均可一键溯源验证。
</div>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F4F3EE;">
<tr><td align="center" style="padding:30px 12px 40px;">

  <table role="presentation" class="wrap" width="620" cellpadding="0" cellspacing="0" border="0" style="width:620px;max-width:620px;background:#FFFFFF;border:1px solid #E6E3DA;border-radius:14px;overflow:hidden;">

    <tr><td style="height:4px;line-height:4px;font-size:4px;background:#0C6151;">&nbsp;</td></tr>

    <!-- header -->
    <tr><td class="px" style="padding:22px 34px 16px;border-bottom:1px solid #EFEEE7;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
        <td style="vertical-align:middle;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
            <td style="vertical-align:middle;font-size:0;line-height:0;"><table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr><td width="11" height="11" style="width:11px;height:11px;background:#0C6151;border-radius:4px;font-size:0;line-height:0;">&nbsp;</td></tr></table></td>
            <td style="vertical-align:middle;font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:18px;font-weight:800;letter-spacing:-.3px;color:#191B18;white-space:nowrap;">&nbsp;Network <span style="color:#0C6151;">Intel</span></td>
            <td style="vertical-align:middle;white-space:nowrap;"><span style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:10px;font-weight:600;letter-spacing:.5px;color:#0C6151;background:#DCE9E4;padding:3px 7px;border-radius:4px;margin-left:8px;vertical-align:2px;">内部情报</span></td>
          </tr></table>
        </td>
        <td align="right" style="vertical-align:middle;font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:12px;color:#878B81;">
          周报 · <span style="color:#191B18;font-weight:600;">{{ report.date_range }}</span>
        </td>
      </tr></table>
    </td></tr>

    <!-- title -->
    <tr><td class="px" style="padding:26px 34px 0;">
      <div style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;font-weight:600;letter-spacing:1.6px;color:#0C6151;text-transform:uppercase;">NETWORK INTEL · 深度周报</div>
      <h1 style="margin:13px 0 0;font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:30px;line-height:1.12;font-weight:800;color:#191B18;letter-spacing:-1px;">{{ report.title }}</h1>
      <div style="margin-top:12px;font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:12px;color:#878B81;">覆盖 {{ report.date_range }} &nbsp;·&nbsp; report.json · {{ report.type }}</div>
    </td></tr>

    <!-- 🎯 strategy block (pinned) -->
    {% if report.strategy %}
    <tr><td class="px" style="padding:24px 34px 0;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#0C6151;border-radius:12px;overflow:hidden;">
        <tr><td style="padding:20px 22px;">
          <div style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9FD3C5;margin-bottom:8px;">🎯 {{ report.strategy.title }}{% if report.strategy.period %} · {{ report.strategy.period }}{% endif %}</div>
          {% if report.strategy.paras %}
            {% for label, body in report.strategy.paras %}
            <div style="margin-top:12px;">
              <div style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:12px;font-weight:800;color:#DCE9E4;letter-spacing:.5px;">{{ label }}</div>
              <div style="margin-top:4px;font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:14px;line-height:1.7;color:#EAF3F0;">{{ body | cite_links(ref_index) }}</div>
            </div>
            {% endfor %}
          {% else %}
            <div style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:15px;line-height:1.7;color:#EAF3F0;">{{ report.strategy.body | cite_links(ref_index) }}</div>
          {% endif %}
        </td></tr>
      </table>
    </td></tr>
    {% endif %}

    <!-- lead -->
    <tr><td class="px" style="padding:24px 34px 0;">
      <div style="border-top:2px solid #191B18;padding-top:20px;">
        <div style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#878B81;margin-bottom:12px;">本周导语 · <span style="color:#0C6151;">Opus 策展</span></div>
        <div style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:17px;line-height:1.7;color:#191B18;font-weight:500;">
          {{ report.lead.text | cite_links(ref_index) }}
          {% if report.lead.strong %}<span style="display:block;margin-top:12px;font-weight:800;font-size:16px;color:#191B18;letter-spacing:-.3px;">{{ report.lead.strong }}</span>{% endif %}
        </div>
      </div>
    </td></tr>

    <!-- tally -->
    {% if report.tally %}
    <tr><td class="px" style="padding:18px 34px 0;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
        <td style="padding-right:7px;"><span style="display:inline-block;padding:5px 11px;border:1px solid #E6E3DA;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#54584F;">信号 {{ report.tally.signals }}</span></td>
        <td style="padding-right:7px;"><span style="display:inline-block;padding:5px 11px;background:#F7ECEE;border:1px solid #ECCBD1;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#B23B4B;">威胁 {{ report.tally.threat }}</span></td>
        <td style="padding-right:7px;"><span style="display:inline-block;padding:5px 11px;background:#E9F2EC;border:1px solid #C9E0D1;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#2E8259;">机会 {{ report.tally.opp }}</span></td>
        <td style="padding-right:7px;"><span style="display:inline-block;padding:5px 11px;border:1px solid #E6E3DA;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#54584F;">中性 {{ report.tally.neutral }}</span></td>
        <td><span style="display:inline-block;padding:5px 11px;background:#DCE9E4;border:1px solid #BFD8CF;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#0C6151;">官方源 {{ report.tally.official }}</span></td>
      </tr></table>
    </td></tr>
    {% endif %}

    <!-- sections -->
    {% for sec in sections %}
    {% set sn = loop.index %}
    {% if sec.meta.key == 'store' %}
      {% if report.store %}
      {{ m.section_header(loop.index, sec.meta.title, sec.meta.desc, report.store|length, SECTION_TONE.get('store')) }}
      <tr><td class="px" style="padding:16px 34px 0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #E6E3DA;border-radius:10px;overflow:hidden;font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;">
          <tr style="background:#F7F6F1;">
            <td style="padding:10px 14px;font-size:11px;font-weight:700;color:#878B81;letter-spacing:.5px;">产品</td>
            <td style="padding:10px 14px;font-size:11px;font-weight:700;color:#878B81;">类别</td>
            <td style="padding:10px 14px;font-size:11px;font-weight:700;color:#878B81;">变化</td>
            <td style="padding:10px 14px;font-size:11px;font-weight:700;color:#878B81;">库存</td>
          </tr>
          {% for row in report.store %}
          {% set dirc = {'up':'#2E8259','down':'#B23B4B','new':'#0C6151','flat':'#7C8079'} %}
          {% set stockc = {'in':'#2E8259','low':'#8A6D1F','out':'#B23B4B'} %}
          <tr style="border-top:1px solid #EFEEE7;">
            <td style="padding:11px 14px;font-size:13px;font-weight:700;color:#191B18;">{{ row.product }}</td>
            <td style="padding:11px 14px;font-size:12px;color:#54584F;">{{ row.cat or '' }}</td>
            <td style="padding:11px 14px;font-size:12px;font-weight:700;color:{{ dirc.get(row.dir, '#54584F') }};">{{ row.change or '' }}</td>
            <td style="padding:11px 14px;font-size:12px;font-weight:600;color:{{ stockc.get(row.stock, '#54584F') }};">{{ {'in':'有货','low':'紧张','out':'缺货'}.get(row.stock, row.stock) }}</td>
          </tr>
          {% endfor %}
        </table>
      </td></tr>
      {% endif %}
    {% elif sec.meta.key == 'dashboard' %}
      {% if report.dashboard %}
      {% set db = report.dashboard %}
      {% set vs = db.vs %}
      {% set vs_ok = vs and ((vs.omada or 0) > 0 or (vs.unifi or 0) > 0) %}
      {% set pains = db.pains or [] %}
      {% set sources = db.sources or [] %}
      {% set topheat = db.topHeat or [] %}

      {# ===== 口碑与痛点分析 (mirrors web DashboardSection sentiment panels) ===== #}
      {{ m.section_header(sn, '口碑与痛点分析', '情感趋势 / 高频痛点 / Omada vs UniFi', none, SECTION_TONE.get('sentiment')) }}

      {# 口碑指数 · 本周: current-week index + real 环比 (from sentimentTrend) + bars #}
      {% if vs_ok %}
      <tr><td class="px" style="padding:16px 34px 0;">
        <div style="background:#F7F6F1;border:1px solid #EFEEE7;border-radius:10px;padding:16px 18px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
            <td style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:13px;font-weight:800;color:#191B18;">口碑指数 · 本周</td>
            <td align="right" style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;color:#878B81;">Omada vs UniFi · 正面口碑</td>
          </tr></table>
          {% set od = vs_delta.omada if vs_delta else none %}
          <div style="margin-top:14px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
              <td style="font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:13px;font-weight:600;color:#54584F;">Omada</td>
              <td align="right" style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:15px;font-weight:800;color:#0C6151;">{{ vs.omada }}{% if od is not none %} <span style="font-size:11px;font-weight:700;color:{{ '#2E8259' if od > 0 else '#B23B4B' if od < 0 else '#878B81' }};">{{ '▲' if od > 0 else '▼' if od < 0 else '' }}{{ '+' if od > 0 else '' }}{{ od }} 环比</span>{% endif %}</td>
            </tr></table>
            {{ m.bar(vs.omada, '#0C6151') }}
          </div>
          {% set ud = vs_delta.unifi if vs_delta else none %}
          <div style="margin-top:13px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
              <td style="font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:13px;font-weight:600;color:#54584F;">UniFi</td>
              <td align="right" style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:15px;font-weight:800;color:#B23B4B;">{{ vs.unifi }}{% if ud is not none %} <span style="font-size:11px;font-weight:700;color:{{ '#2E8259' if ud > 0 else '#B23B4B' if ud < 0 else '#878B81' }};">{{ '▲' if ud > 0 else '▼' if ud < 0 else '' }}{{ '+' if ud > 0 else '' }}{{ ud }} 环比</span>{% endif %}</td>
            </tr></table>
            {{ m.bar(vs.unifi, '#B23B4B') }}
          </div>
        </div>
      </td></tr>
      {% else %}
      {{ m.empty_note('环比口碑对比需上周数据，正在积累中') }}
      {% endif %}

      {# 高频痛点 Top 5 (UniFi 社区 · 本周) #}
      <tr><td class="px" style="padding:20px 34px 0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
          <td style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:13px;font-weight:800;color:#191B18;">高频痛点 Top 5</td>
          <td align="right" style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;color:#878B81;">UniFi 社区 · 本周</td>
        </tr></table>
      </td></tr>
      {% if pains %}
      <tr><td class="px" style="padding:10px 34px 0;">
        <div style="background:#F7F6F1;border:1px solid #EFEEE7;border-radius:10px;padding:14px 18px;">
          {% for p in pains %}
          <div style="{% if not loop.first %}margin-top:13px;{% endif %}">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
              <td style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:13px;font-weight:600;color:#34372F;">{{ p.name }}</td>
              <td align="right" style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:13px;font-weight:800;color:#191B18;">{{ p.count }}</td>
            </tr></table>
            {{ m.bar((p.count / p.of * 100) if p.of else 0, '#B23B4B' if loop.index <= 2 else '#0C6151') }}
          </div>
          {% endfor %}
        </div>
      </td></tr>
      {% else %}
      {{ m.empty_note('高频痛点需更多样本统计，正在积累中') }}
      {% endif %}

      {# ===== 数据看板 (KPI / 各源贡献 / 热度 Top) ===== #}
      {{ m.section_header(sn + 1, '数据看板', '信号量 / 各源贡献 / 热度 Top', none, SECTION_TONE.get('industry')) }}

      {# KPI × 4 (2×2) #}
      <tr><td class="px" style="padding:16px 34px 0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr>
            {{ m.kpi_num('本周信号量', db.signals, db.signalsDelta) }}
            {{ m.kpi_sub('威胁 / 机会', (db.threats|string) ~ ' / ' ~ (db.opps|string), ((db.neutral|string) ~ ' 中性') if db.neutral is not none else none) }}
          </tr>
          <tr>
            {{ m.kpi_num('新竞品动作', db.newCompetitor or 0, db.newCompetitorDelta) }}
            {{ m.kpi_num('平均热度', db.avgHeat if db.avgHeat is not none else '—', db.avgHeatDelta) }}
          </tr>
        </table>
      </td></tr>

      {# 各源贡献 #}
      {% if sources %}
      <tr><td class="px" style="padding:16px 34px 0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
          <td style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:13px;font-weight:800;color:#191B18;">各源贡献</td>
          <td align="right" style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;color:#878B81;">本周 {{ db.signals }} 条</td>
        </tr></table>
      </td></tr>
      <tr><td class="px" style="padding:10px 34px 0;">
        <div style="background:#F7F6F1;border:1px solid #EFEEE7;border-radius:10px;padding:14px 18px;">
          {% set smax = sources[0].count or 1 %}
          {% for s in sources %}
          <div style="{% if not loop.first %}margin-top:13px;{% endif %}">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
              <td style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:13px;font-weight:600;color:#54584F;">{{ s.label }}</td>
              <td align="right" style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:13px;font-weight:800;color:#191B18;">{{ s.count }}</td>
            </tr></table>
            {{ m.bar(s.count / smax * 100, '#0C6151') }}
          </div>
          {% endfor %}
        </div>
      </td></tr>
      {% endif %}

      {# 热度 Top 5 #}
      {% if topheat %}
      <tr><td class="px" style="padding:16px 34px 0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
          <td style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:13px;font-weight:800;color:#191B18;">热度 Top 5</td>
          <td align="right" style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;color:#878B81;">赞 + 评论加权</td>
        </tr></table>
      </td></tr>
      <tr><td class="px" style="padding:10px 34px 0;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F7F6F1;border:1px solid #EFEEE7;border-radius:10px;">
          {% for h in topheat %}
          {% set it = item_by_id.get(h.id) %}
          <tr>
            <td width="34" valign="top" style="padding:{{ '14px' if loop.first else '12px' }} 4px 12px 18px;font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:13px;font-weight:800;color:{{ '#0C6151' if loop.first else '#A8AC9F' }};{% if not loop.first %}border-top:1px solid #EFEEE7;{% endif %}">{{ '%02d'|format(loop.index) }}</td>
            <td valign="top" style="padding:12px 8px;{% if not loop.first %}border-top:1px solid #EFEEE7;{% endif %}">
              <div style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:13.5px;font-weight:600;color:#191B18;line-height:1.4;">{{ it.title if it else h.id }}</div>
              {% if it %}<div style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;color:#878B81;margin-top:3px;">{{ it.source_label or it.source_domain }} · {{ it.category | category_label }}</div>{% endif %}
            </td>
            <td align="right" valign="top" style="padding:12px 18px 12px 4px;white-space:nowrap;{% if not loop.first %}border-top:1px solid #EFEEE7;{% endif %}font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:13px;font-weight:800;color:#191B18;">{{ '{:,}'.format(h.v) }}{% if h.fmt == 'views' %} 播放{% endif %}</td>
          </tr>
          {% endfor %}
        </table>
      </td></tr>
      {% endif %}
      {% endif %}
    {% elif sec.insights %}
      {% set tone = SECTION_TONE.get(sec.meta.key, '#191B18') %}
      {{ m.section_header(sn, sec.meta.title, sec.meta.desc, sec.insights|length, tone) }}
      {% for entry in sec.insights %}{{ m.insight_card(entry, sn ~ '.' ~ loop.index, ref_index, tone) }}{% endfor %}
    {% elif sec.entries %}
      {{ m.section_header(sn, sec.meta.title, sec.meta.desc, sec.entries|length, SECTION_TONE.get(sec.meta.key, '#191B18')) }}
      {% for item in sec.entries %}{{ m.intel_card(item) }}{% endfor %}
    {% endif %}
    {% endfor %}

    {{ m.references_block(references) }}
    {{ m.footer(report, site_url) }}

  </table>

  <div style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;color:#A8AC9F;padding:16px 12px 0;">本邮件由 report.json 渲染 · 每条结论均可一键溯源验证</div>

</td></tr>
</table>
</body>
</html>
