{% import '_macros.html.j2' as m %}
<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="x-apple-disable-message-reformatting">
<meta name="color-scheme" content="light">
<meta name="supported-color-schemes" content="light">
<title>Network Intel · {{ report.date }} · 日报</title>
<!--[if mso]><style>*{font-family:'Segoe UI',Arial,sans-serif !important;}</style><![endif]-->
<style>
  a{text-decoration:none;}
  .hov:hover{opacity:.82;}
  @media only screen and (max-width:620px){
    .wrap{width:100% !important;}
    .px{padding-left:18px !important;padding-right:18px !important;}
    .stack{display:block !important;width:100% !important;}
  }
</style>
</head>
<body style="margin:0;padding:0;background:#F4F3EE;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">

<div style="display:none;max-height:0;overflow:hidden;opacity:0;color:#F4F3EE;font-size:1px;line-height:1px;">
  {{ report.lead.strong or report.title }} — 每条结论均可一键溯源验证。
</div>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#F4F3EE;">
<tr><td align="center" style="padding:30px 12px 40px;">

  <table role="presentation" class="wrap" width="620" cellpadding="0" cellspacing="0" border="0" style="width:620px;max-width:620px;background:#FFFFFF;border:1px solid #E6E3DA;border-radius:14px;overflow:hidden;">

    <tr><td style="height:4px;line-height:4px;font-size:4px;background:#0C6151;">&nbsp;</td></tr>

    <!-- header -->
    <tr><td class="px" style="padding:22px 34px 16px;border-bottom:1px solid #EFEEE7;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
        <td style="vertical-align:middle;">
          <span style="display:inline-block;width:11px;height:11px;border-radius:4px;background:#0C6151;vertical-align:-1px;"></span>
          <span style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:18px;font-weight:800;letter-spacing:-.3px;color:#191B18;">&nbsp;Network <span style="color:#0C6151;">Intel</span></span>
          <span style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:10px;font-weight:600;letter-spacing:.5px;color:#0C6151;background:#DCE9E4;padding:3px 7px;border-radius:4px;margin-left:8px;vertical-align:2px;">内部情报</span>
        </td>
        <td align="right" style="vertical-align:middle;font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:12px;color:#878B81;">
          日报 · <span style="color:#191B18;font-weight:600;">{{ report.date }}</span>
        </td>
      </tr></table>
    </td></tr>

    <!-- title -->
    <tr><td class="px" style="padding:26px 34px 0;">
      <div style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;font-weight:600;letter-spacing:1.6px;color:#0C6151;text-transform:uppercase;">NETWORK INTEL · 内部竞品情报</div>
      <h1 style="margin:13px 0 0;font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:30px;line-height:1.12;font-weight:800;color:#191B18;letter-spacing:-1px;">{{ report.title }}</h1>
      <div style="margin-top:12px;font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:12px;color:#878B81;">覆盖 {{ report.date_range }} &nbsp;·&nbsp; report.json · {{ report.type }}</div>
    </td></tr>

    <!-- lead -->
    <tr><td class="px" style="padding:24px 34px 0;">
      <div style="border-top:2px solid #191B18;padding-top:20px;">
        <div style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#878B81;margin-bottom:12px;">本期导语 · <span style="color:#0C6151;">Opus 策展</span></div>
        <div style="font-family:-apple-system,'Segoe UI','PingFang SC','Microsoft YaHei',Arial,sans-serif;font-size:17px;line-height:1.7;color:#191B18;font-weight:500;">
          {{ report.lead.text | cite_links(ref_index) }}
          {% if report.lead.strong %}<span style="display:block;margin-top:12px;font-weight:800;font-size:16px;color:#191B18;letter-spacing:-.3px;">{{ report.lead.strong }}</span>{% endif %}
        </div>
      </div>
    </td></tr>

    <!-- tally -->
    {% if report.tally %}
    <tr><td class="px" style="padding:18px 34px 0;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr>
        <td style="padding-right:7px;"><span style="display:inline-block;padding:5px 11px;border:1px solid #E6E3DA;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#54584F;">信号 {{ report.tally.signals }}</span></td>
        <td style="padding-right:7px;"><span style="display:inline-block;padding:5px 11px;background:#F7ECEE;border:1px solid #ECCBD1;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#B23B4B;">威胁 {{ report.tally.threat }}</span></td>
        <td style="padding-right:7px;"><span style="display:inline-block;padding:5px 11px;background:#E9F2EC;border:1px solid #C9E0D1;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#2E8259;">机会 {{ report.tally.opp }}</span></td>
        <td style="padding-right:7px;"><span style="display:inline-block;padding:5px 11px;border:1px solid #E6E3DA;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#54584F;">中性 {{ report.tally.neutral }}</span></td>
        <td><span style="display:inline-block;padding:5px 11px;background:#DCE9E4;border:1px solid #BFD8CF;border-radius:999px;font-family:-apple-system,'Segoe UI',Arial,sans-serif;font-size:12px;font-weight:600;color:#0C6151;">官方源 {{ report.tally.official }}</span></td>
      </tr></table>
    </td></tr>
    {% endif %}

    <!-- sections -->
    {% for sec in sections %}
    {% if sec.entries %}
    {{ m.section_header(loop.index, sec.meta.title, sec.meta.desc, sec.entries|length, SECTION_TONE.get(sec.meta.key, '#191B18')) }}
    {% for item in sec.entries %}{{ m.intel_card(item) }}{% endfor %}
    {% endif %}
    {% endfor %}

    {{ m.references_block(references) }}
    {{ m.footer(report) }}

  </table>

  <div style="font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;color:#A8AC9F;padding:16px 12px 0;">本邮件由 report.json 渲染 · 每条结论均可一键溯源验证</div>

</td></tr>
</table>
</body>
</html>
